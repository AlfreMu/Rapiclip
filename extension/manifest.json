{
  "manifest_version": 3,
  "name": "Rapiclip",
  "version": "0.1.0",
  "description": "Comparti un clip facil en Youtube.",
  "icons": {
    "16": "icons/icons16.png",
    "32": "icons/icons32.png",
    "48": "icons/icons48.png",
    "128": "icons/icons128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icons16.png",
      "32": "icons/icons32.png",
      "48": "icons/icons48.png",
      "128": "icons/icons128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
